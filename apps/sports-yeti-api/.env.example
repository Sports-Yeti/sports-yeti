APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ============================================================================
# AUTH (JWT)
# ============================================================================
# Generate with: php artisan jwt:secret
JWT_SECRET=

# ============================================================================
# OBSERVABILITY CONFIGURATION
# ============================================================================

# OpenTelemetry Configuration
# Enable/disable distributed tracing
OTEL_ENABLED=false
OTEL_SERVICE_NAME=sports-yeti-api
OTEL_SERVICE_VERSION=1.0.0
OTEL_SERVICE_ENVIRONMENT=local

# OTLP Exporter Configuration
# For local Jaeger: http://localhost:4318
# For Grafana Tempo: https://tempo-gateway.your-domain.com
# For Honeycomb: https://api.honeycomb.io:443
# For New Relic: https://otlp.nr-data.net:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# Format: key1=value1,key2=value2 (e.g., x-honeycomb-team=YOUR_API_KEY)
OTEL_EXPORTER_OTLP_HEADERS=

# Sampling Configuration
# Options: always_on, always_off, traceidratio, parentbased_traceidratio
OTEL_TRACES_SAMPLER=always_on
# Ratio for traceidratio samplers (0.0 to 1.0)
OTEL_TRACES_SAMPLER_ARG=1.0

# Span Processor (batch for production, simple for debugging)
OTEL_SPAN_PROCESSOR=batch

# Prometheus Metrics Configuration
PROMETHEUS_ENABLED=true
PROMETHEUS_NAMESPACE=sports_yeti_api
# Storage: memory (dev), redis (production)
PROMETHEUS_STORAGE=memory

# Redis storage for Prometheus (when PROMETHEUS_STORAGE=redis)
PROMETHEUS_REDIS_HOST=127.0.0.1
PROMETHEUS_REDIS_PORT=6379
PROMETHEUS_REDIS_PASSWORD=null
PROMETHEUS_REDIS_DATABASE=1

# Structured JSON Logging
# Set LOG_CHANNEL=json or LOG_CHANNEL=json-stdout for production
# LOG_CHANNEL=json

# ============================================================================
# AI CONFIGURATION (Laravel AI SDK)
# ============================================================================
GEMINI_API_KEY=

# ============================================================================
# HIGHLIGHTS CONFIGURATION
# ============================================================================
HIGHLIGHT_PRICE=1.99
HIGHLIGHT_CURRENCY=usd
HIGHLIGHT_MAX_VIDEO_MB=200
HIGHLIGHT_MAX_DURATION=3600
HIGHLIGHT_MAX_CLIPS=15
HIGHLIGHT_STORAGE_DISK=public
