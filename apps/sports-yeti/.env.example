# Sports Yeti Mobile App Environment Variables

# API Configuration
# localhost works on simulators/emulators only. On a physical device via Expo Go,
# use your machine's LAN IP (see `ipconfig getifaddr en0` on macOS).
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
# EXPO_PUBLIC_API_URL=http://192.168.1.xxx:8000/api/v1

# Sentry Configuration (for crash reporting and observability)
EXPO_PUBLIC_SENTRY_DSN=https://d9b81640898507f5e557c1a9438d98a7@o4510801877794816.ingest.us.sentry.io/4510831672295424

# App Version (used for Sentry release tracking)
EXPO_PUBLIC_APP_VERSION=1.0.0
