{
  "expo": {
    "name": "SportsYeti",
    "slug": "@sports-yeti/sports-yeti",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
  "plugins": [],
  "extra": {
    "USE_FIXTURES": true,
    "API_BASE_URL": "https://api.sportsyeti.example.com/api/v1",
    "API_BASE_URL_DEV_ANDROID": "http://10.0.2.2:8000/api/v1",
    "API_BASE_URL_DEV_IOS": "http://localhost:8000/api/v1",
    "DATADOG_ENABLED": false,
    "SENTRY_DSN": ""
  }
  }
}
